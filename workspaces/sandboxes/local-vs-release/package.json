{
  "name": "@pacwich/sandbox--local-vs-release",
  "private": true,
  "scripts": {
    "api:local": "bun run src/local.ts",
    "cli:local": "bun node_modules/pacwich_local/bin/cli.js --cwd=test-project",
    "api:release": "bun run src/release.ts",
    "cli:release": "bun node_modules/pacwich_release/bin/cli.js --cwd=test-project",
    "prepare": "cd test-project && bun install"
  },
  "devDependencies": {
    "pacwich_release": "npm:pacwich@latest"
  }
}
