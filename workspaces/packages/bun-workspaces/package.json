{
  "name": "bun-workspaces",
  "version": "1.12.0",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli/index.ts",
    "./config": "./src/config/public.ts",
    "./script": "./src/runScript/public.ts"
  },
  "private": true,
  "description": "A monorepo management tool for Bun, with a CLI and API to enhance Bun's native workspaces.",
  "homepage": "https://bunworkspaces.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bun-workspaces/bun-workspaces.git"
  },
  "keywords": [
    "bun",
    "workspace",
    "workspaces",
    "monorepo",
    "cli",
    "api"
  ],
  "bin": {
    "bun-workspaces": "bin/cli.js",
    "bw": "bin/cli.js"
  },
  "_bwInternal": {
    "bunVersion": {
      "build": "1.3.5",
      "libraryConsumer": "^1.2.0"
    }
  },
  "scripts": {
    "cli": "bun  run bin/cli.js",
    "cli:dev": "_BW_RUNTIME_MODE=development bun  run bin/cli.js",
    "cli:build": "bun  run dist/bin/cli.js",
    "ajv": "bun run scripts/ajv.ts",
    "create-public-agent-docs": "bun  run scripts/createPublicAgentDocs.ts",
    "test": "rm -rf dist.test && bun test --timeout 10000",
    "test:clean": "rm -rf tests/fixtures/testProjects/**/node_modules && rm -rf tests/fixtures/testProjects/**/bun.lock && bun run test",
    "test:concurrent": "rm -rf dist.test && bun  test --concurrent --timeout 10000",
    "lint": "eslint src",
    "build": "bun run scripts/build.ts",
    "build:test": "BUILD_INCLUDE_TESTS=true bun  run scripts/build.ts && chmod +x dist.test/bin/cli.js && cd dist.test && bun install && IS_BUILD=true bun  run test",
    "build:rslib-only": "rslib build",
    "type-check": "tsc --noEmit",
    "create-modules": "bun run ajv && bun run create-public-agent-docs",
    "mcp:inspect": "mcp-inspector bun  run bin/cli.js --cwd ../../../ mcp"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "catalog:bun-workspaces-dev",
    "@rslib/core": "catalog:bun-workspaces-dev",
    "@types/shell-quote": "catalog:bun-workspaces-dev",
    "@xterm/headless": "catalog:bun-workspaces-dev",
    "ajv": "catalog:bun-workspaces-dev",
    "dts-bundle-generator": "catalog:bun-workspaces-dev"
  },
  "dependencies": {
    "bw-common": "workspace:*",
    "commander": "catalog:bun-workspaces-prod",
    "shell-quote": "catalog:bun-workspaces-prod"
  }
}
