{
  "name": "npm-smoke-root",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "npm-smoke-root",
      "workspaces": [
        "workspaces/*"
      ]
    },
    "node_modules/workspace-a": {
      "resolved": "workspaces/a",
      "link": true
    },
    "node_modules/workspace-b": {
      "resolved": "workspaces/b",
      "link": true
    },
    "workspaces/a": {
      "name": "workspace-a",
      "version": "1.0.0"
    },
    "workspaces/b": {
      "name": "workspace-b",
      "version": "1.0.0",
      "dependencies": {
        "workspace-a": "*"
      }
    }
  }
}
