{
  "name": "test-root",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "test-root",
      "workspaces": [
        "applications/*",
        "libraries/*"
      ]
    },
    "applications/applicationA": {
      "name": "application-1a"
    },
    "applications/applicationB": {
      "name": "application-1b"
    },
    "libraries/libraryA": {
      "name": "library-1a"
    },
    "libraries/libraryB": {
      "name": "library-1b"
    },
    "node_modules/application-1a": {
      "resolved": "applications/applicationA",
      "link": true
    },
    "node_modules/application-1b": {
      "resolved": "applications/applicationB",
      "link": true
    },
    "node_modules/library-1a": {
      "resolved": "libraries/libraryA",
      "link": true
    },
    "node_modules/library-1b": {
      "resolved": "libraries/libraryB",
      "link": true
    }
  }
}
