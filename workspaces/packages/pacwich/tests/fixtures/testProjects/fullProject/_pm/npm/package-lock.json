{
  "name": "test-root",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "test-root",
      "workspaces": [
        "applications/*",
        "libraries/**/*"
      ]
    },
    "applications/applicationA": {
      "name": "application-a"
    },
    "applications/applicationB": {
      "name": "application-b"
    },
    "libraries/libraryA": {
      "name": "library-a"
    },
    "libraries/libraryB": {
      "name": "library-b"
    },
    "libraries/nested/libraryC": {
      "name": "library-c"
    },
    "node_modules/application-a": {
      "resolved": "applications/applicationA",
      "link": true
    },
    "node_modules/application-b": {
      "resolved": "applications/applicationB",
      "link": true
    },
    "node_modules/library-a": {
      "resolved": "libraries/libraryA",
      "link": true
    },
    "node_modules/library-b": {
      "resolved": "libraries/libraryB",
      "link": true
    },
    "node_modules/library-c": {
      "resolved": "libraries/nested/libraryC",
      "link": true
    }
  }
}
