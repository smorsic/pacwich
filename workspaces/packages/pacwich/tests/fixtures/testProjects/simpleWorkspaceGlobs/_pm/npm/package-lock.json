    "node_modules/package-b": {
      "resolved": "packageB",
      "link": true
    },
    "node_modules/package-c": {
      "resolved": "packageC",
      "link": true
    },
    "packageA": {
      "name": "package-a"
    },
    "packageB": {
      "name": "package-b"
    },
    "packageC": {
      "name": "package-c"
    }
  }
