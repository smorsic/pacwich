{
  "name": "semver-workspace-link-root",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "semver-workspace-link-root",
      "version": "1.0.0",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/pkg-a": {
      "resolved": "packages/pkg-a",
      "link": true
    },
    "node_modules/pkg-b": {
      "resolved": "packages/pkg-b",
      "link": true
    },
    "packages/pkg-a": {
      "version": "1.2.3"
    },
    "packages/pkg-b": {
      "version": "1.0.0",
      "dependencies": {
        "pkg-a": "^1.0.0"
      }
    }
  }
}
