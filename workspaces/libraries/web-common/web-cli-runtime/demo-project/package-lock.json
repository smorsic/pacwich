{
  "name": "demo-monorepo",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "demo-monorepo",
      "version": "1.0.0",
      "workspaces": [
        "packages/*",
        "apps/*"
      ]
    },
    "packages/utils": {
      "name": "@demo/utils",
      "version": "1.0.0"
    },
    "packages/core": {
      "name": "@demo/core",
      "version": "1.0.0"
    },
    "apps/web": {
      "name": "@demo/web",
      "version": "1.0.0"
    },
    "node_modules/@demo/utils": {
      "resolved": "@demo/utils",
      "link": true
    },
    "node_modules/@demo/core": {
      "resolved": "@demo/core",
      "link": true
    },
    "node_modules/@demo/web": {
      "resolved": "@demo/web",
      "link": true
    }
  }
}
