{
  "name": "@pacwich/documentation-website",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PACWICH_DOCS_ENV=development portless pacwich-docs rspress dev --host",
    "dev:plain": "PACWICH_DOCS_ENV=development rspress dev",
    "lint": "eslint src/",
    "build": "PACWICH_DOCS_ENV=production bun run scripts/build.ts",
    "build:dev": "PACWICH_DOCS_ENV=development bun run scripts/build.ts",
    "build:rspress-only": "SKIP_PACWICH_BUILD=true bunx rspress build",
    "preview": "portless pacwich-docs-preview rspress preview",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@fontsource/unifontex": "catalog:web",
    "@rsbuild/core": "^2.0.8",
    "@rsbuild/plugin-node-polyfill": "^1.4.6",
    "@rsbuild/plugin-svgr": "catalog:web",
    "@rspress/core": "catalog:web",
    "@rspress/plugin-client-redirects": "catalog:web",
    "@rspress/plugin-sitemap": "catalog:web",
    "@types/lodash": "catalog:web",
    "@types/react": "catalog:web",
    "@types/react-syntax-highlighter": "catalog:web",
    "@pacwich/common": "workspace:*",
    "@pacwich/web-cli": "workspace:*",
    "lodash": "catalog:web",
    "pacwich_local": "workspace:*",
    "react": "catalog:web",
    "react-dom": "catalog:web",
    "react-icons": "catalog:web",
    "react-router": "catalog:web",
    "react-router-dom": "catalog:web",
    "react-syntax-highlighter": "catalog:web",
    "zustand": "catalog:web"
  }
}
