{
  "extends": "../../meta/config/base/tsconfig.json",
  "compilerOptions": {
    // We consume the `pacwich` package as raw TS source (workspace dep). Its
    // generated ajv `.js` validators ship without declarations; tsc surfaces
    // them as implicit-any imports. They're the dependency's internals, not
    // ours, so relax this for the cross-package boundary.
    "noImplicitAny": false,
    // The demo project is loaded from static `.json` files (see demoProject.ts).
    "resolveJsonModule": true,
    // demo-project/pacwich.project.ts imports "pacwich/config" (the real
    // published name, matching genuine end-user syntax) for type-checking
    // purposes here; this workspace otherwise depends on the local build
    // under "pacwich_local" to avoid clashing with the published package.
    "paths": {
      "pacwich/config": ["../../packages/pacwich/src/config/public.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.json",
    "tests/**/*.ts",
    "rspress.config.ts"
  ],
  "exclude": ["node_modules", "dist", "doc_build"]
}
