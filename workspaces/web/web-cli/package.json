{
  "name": "@pacwich/web-cli",
  "private": true,
  "type": "module",
  "description": "Run the real pacwich CLI in the browser over an in-memory filesystem (memfs). Exports the engine, the demo project, the shared UI, and the bundler wiring the docs site renders on its Web CLI page.",
  "exports": {
    ".": "./src/engine/index.ts",
    "./demo-project": "./src/demo-project/index.ts",
    "./ui": "./src/ui/index.tsx",
    "./bundler": "./src/bundler/index.ts",
    "./engine/*": "./src/engine/*.ts"
  },
  "scripts": {
    "dev": "bunx rsbuild dev",
    "build": "bunx rsbuild build",
    "preview": "bunx rsbuild preview",
    "lint": "bunx eslint src",
    "type-check": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@pacwich/web-common": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "pacwich": "latest",
    "react-arborist": "catalog:web",
    "react-icons": "catalog:web",
    "react-syntax-highlighter": "catalog:web",
    "shell-quote": "catalog:pacwich-prod",
    "zustand": "catalog:web"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.0.8",
    "@rsbuild/plugin-node-polyfill": "^1.4.6",
    "@rsbuild/plugin-react": "^2.0.0",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "catalog:web",
    "@types/react-dom": "^19.2.0",
    "@types/react-syntax-highlighter": "catalog:web",
    "@types/shell-quote": "catalog:pacwich-dev",
    "memfs": "^4.17.0",
    "path-browserify": "^1.0.1",
    "react": "catalog:web",
    "react-dom": "catalog:web"
  }
}
