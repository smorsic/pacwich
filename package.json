{
  "name": "pacwich-source-monorepo",
  "private": true,
  "license": "MIT",
  "workspaces": {
    "packages": [
      "workspaces/**/*",
      "!workspaces/packages/pacwich/**/*",
      "!workspaces/sandboxes/local-vs-release/**/*",
      "!workspaces/web/web-cli/src/web-cli-runtime/**/*"
    ],
    "catalog": {},
    "catalogs": {
      "pacwich-prod": {
        "commander": "12.1.0",
        "jiti": "2.7.0",
        "semver": "7.8.0",
        "shell-quote": "1.8.4",
        "sucrase": "3.35.1",
        "yaml": "2.9.0"
      },
      "pacwich-dev": {
        "@modelcontextprotocol/inspector": "^0.21.1",
        "@rslib/core": "^0.21.2",
        "@types/semver": "^7.7.1",
        "@types/shell-quote": "^1.7.5",
        "@xterm/headless": "^6.0.0",
        "ajv": "^8.17.1",
        "knip": "^6.15.0",
        "dts-bundle-generator": "^9.5.1",
        "vitest": "^4.1.6"
      },
      "web": {
        "@fontsource/unifontex": "^5.2.6",
        "@rsbuild/core": "^2.0.8",
        "@rsbuild/plugin-node-polyfill": "^1.4.6",
        "@rsbuild/plugin-svgr": "^1.3.1",
        "@rspress/core": "^2.0.12",
        "@rspress/plugin-client-redirects": "^2.0.12",
        "@rspress/plugin-sitemap": "^2.0.12",
        "@types/lodash": "^4.17.24",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.0",
        "@types/react-syntax-highlighter": "^15.5.13",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0.0",
        "lodash": "^4.18.1",
        "react": "^19.2.6",
        "react-arborist": "^3.7.0",
        "react-dom": "^19.2.6",
        "react-icons": "^5.6.0",
        "react-router": "^7.15.1",
        "react-router-dom": "^7.15.1",
        "react-syntax-highlighter": "^16.1.1",
        "zustand": "^5.0.13"
      }
    }
  },
  "scripts": {
    "cli:bun": "bun workspaces/packages/pacwich/dist/bin/cli.js",
    "cli:node": "node workspaces/packages/pacwich/dist/bin/cli.js",
    "pw": "pacwich ri --workspace=pw --script",
    "docs": "pacwich ri --workspace=docs --script",
    "wc": "pacwich ri --workspace=wc --script",
    "sandbox": "pacwich ri --workspace=sandbox --script",
    "lint": "pacwich run lint '*' not:tag:sandbox",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "test": "pacwich run test --",
    "type-check": "pacwich run type-check -P --",
    "mcp-server": "pacwich mcp-server",
    "create-agents-md": "pacwich -l warn ri create-agents-md meta",
    "create-readme": "pacwich -l warn ri create-readme meta",
    "create-mise-toml": "pacwich -l warn ri create-mise-toml meta",
    "create-claude-skill-links": "pacwich -l warn ri create-claude-skill-links meta",
    "print-dev-bun-version": "pacwich -l silent ri print-dev-tool-version -- bun",
    "print-dev-node-version": "pacwich -l silent ri print-dev-tool-version -- node",
    "mise": "bun mise.ts",
    "portless-start": "portless proxy start --no-tls",
    "portless-stop": "portless proxy stop",
    "init-pacwich-package": "PACWICH_PROJECT_PATH=$PWD bun --cwd=workspaces/packages/pacwich run create-modules && bun --cwd=workspaces/libraries/pacwich-common run build:dts",
    "init-web-cli": "bun wc generate-demo-config",
    "prepare": "bun prepare.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@pacwich/meta": "workspace:*",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "json-schema-to-ts": "^3.1.1",
    "lint-staged": "^17.0.8",
    "pacwich_local": "workspace:*",
    "portless": "^0.13.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css,md,mdx,yaml,yml}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
